    <h1>Codigo utilizado para linkar paginas de codigo uma na outra</h1>
    <link rel="stylesheet" href="style.css">

    <h1>Codigo para colocar audio</h1>
    <h2>Reproduzindo Áudio</h2>
    <audio src="Mídias/happy-mistake.mp3" controls autoplay></audio>
    <!-- MP3 WAV OGG -->
    <audio preload="metadata" autoplay controls loop>
        <source src="Mídias/guanacast-33.mp3" type="audio/mpeg">
        <source src="Mídias/guanacast-33.ogg" type="audio/ogg">
        <source src="Mídias/guanacast-33.mp3" type="audio/wav">
    </audio> 
    <h1>Codigo para colocar video</h1>
    <video src="mídias/meu-video.mp4" width="500" controls></video>

     <video width="500" poster="imagens/limoes-capa.png" controls>
        <source src="mídias/meu-video.mp4" type="video/mp4">
        <source src="mídias/meu-video.m4v" type="video/m4v">
        <source src="mídias/meu-video.webm"type="video/webm">
        <source src="mídias/meu-video.ogv" type="video/ogg">
    </video>
</body>
</html>
